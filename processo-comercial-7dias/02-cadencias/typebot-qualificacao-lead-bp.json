  "_setup_notes": {
    "substituir_antes_de_publicar": [
      "SEU_N8N_URL — trocar pela URL real do n8n (ex: https://n8n.clinicalucrativa.ia.br)",
      "wa.me/557XXXXXXXXX — trocar pelo número WhatsApp Business do Bairro da Paz"
    ],
    "como_importar": [
      "1. Acessar Typebot self-hosted (Easypanel)",
      "2. Criar novo typebot → Import → selecionar este arquivo JSON",
      "3. Publicar o typebot",
      "4. Copiar o link público do bot",
      "5. Gerar QR Code do link para panfleto e faixa"
    ],
    "como_usar_o_link": [
      "Panfleto: imprimir QR Code do link do Typebot",
      "Faixa: imprimir QR Code ao lado do número WhatsApp",
      "Instagram: link na bio + stories com 'Arrasta pra cima'",
      "WhatsApp: enviar link no grupo de moradores"
    ],
    "integracao_n8n_a9": [
      "Este Typebot envia um POST para SEU_N8N_URL/webhook/sst-bp-lead-novo",
      "O workflow n8n-typebot-bp-chatwoot.json (A9) deve receber esse webhook",
      "A9 classifica o lead (quente/morno/frio) e notifica o Closer no Chatwoot"
    ],
    "classificacao_de_leads": {
      "quente": "interesse=sim → Closer recebe alerta imediato no WhatsApp",
      "morno":  "interesse=nao mas respondeu todas as perguntas → cadência D+1/D+3/D+7",
      "frio":   "saiu no início (não quis responder) → lista de transmissão mensal"
    },
    "tema": "Dark mode — paleta SST Card (azul #1987c3, fundo #0f172a). Ajustar cores no Typebot se necessário."
  }
