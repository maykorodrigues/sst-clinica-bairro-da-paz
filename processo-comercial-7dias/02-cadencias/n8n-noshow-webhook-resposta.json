            { "id": "data_ultimo_contato", "displayName": "data_ultimo_contato", "required": false, "defaultMatch": false, "canBeUsedToMatch": false, "display": true, "type": "string", "readOnly": false, "removed": false },
            { "id": "log_disparo", "displayName": "log_disparo", "required": false, "defaultMatch": false, "canBeUsedToMatch": false, "display": true, "type": "string", "readOnly": false, "removed": false },
            { "id": "fase_cadencia", "displayName": "fase_cadencia", "required": false, "defaultMatch": false, "canBeUsedToMatch": false, "display": true, "type": "string", "readOnly": false, "removed": false },
            { "id": "row_number", "displayName": "row_number", "required": false, "defaultMatch": true, "canBeUsedToMatch": true, "display": true, "type": "number", "readOnly": false, "removed": false }
          ]
        },
        "options": {}
      },
      "id": "b1b2c3d4-0007-0007-0007-100000000007",
