{
  "name": "SST No-Show Lab — Webhook Resposta Paciente",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sst-noshow-resposta",
        "responseMode": "onReceived",
        "responseData": "firstEntryJson",
        "options": {}
      },
      "id": "b1b2c3d4-0001-0001-0001-100000000001",
      "name": "Webhook Evolution Resposta",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [120, 300],
      "webhookId": "sst-noshow-resposta"
    },
    {
      "parameters": {
        "jsCode": "// Extrair número do remetente dependendo do formato da Evolution API\nconst body = $input.first().json;\n\nlet numeroRemetente = '';\n\n// Evolution API v2 — formato típico de webhook\nif (body.data && body.data.key && body.data.key.remoteJid) {\n  numeroRemetente = body.data.key.remoteJid.replace('@s.whatsapp.net', '').replace('@c.us', '');\n} else if (body.from) {\n  numeroRemetente = String(body.from).replace('@s.whatsapp.net', '').replace('@c.us', '');\n} else if (body.key && body.key.remoteJid) {\n  numeroRemetente = body.key.remoteJid.replace('@s.whatsapp.net', '').replace('@c.us', '');\n}\n\n// Limpar número (manter apenas dígitos)\nnumeroRemetente = numeroRemetente.replace(/\\D/g, '');\n\nif (!numeroRemetente) {\n  return [{ json: { encontrado: false, motivo: 'numero_nao_identificado' } }];\n}\n\nreturn [{\n  json: {\n    numero_remetente: numeroRemetente,\n    mensagem_recebida: body?.data?.message?.conversation || body?.message || '',\n    raw: body\n  }\n}];"
      },
      "id": "b1b2c3d4-0002-0002-0002-100000000002",
      "name": "Extrair Número Remetente",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [340, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "leftValue": "={{ $json.numero_remetente }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "b1b2c3d4-0003-0003-0003-100000000003",
      "name": "Tem Número?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [560, 300]
    },
    {
      "parameters": {
        "operation": "readAllRows",
        "documentId": {
          "value": "={{ $env.SST_SHEETS_ID }}",
          "__rl": true,
          "mode": "id"
        },
        "sheetName": {
          "value": "No-Show Lab",
          "__rl": true,
          "mode": "name"
        },
        "options": {
          "headerRow": 1
        }
      },
      "id": "b1b2c3d4-0004-0004-0004-100000000004",
      "name": "Ler Sheets (buscar paciente)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [780, 180],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "SUBSTITUIR_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets SST"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const numeroRemetente = $('Extrair Número Remetente').first().json.numero_remetente;\nconst mensagem = $('Extrair Número Remetente').first().json.mensagem_recebida;\nconst todasLinhas = $input.all();\n\n// Buscar paciente pelo número de WhatsApp\nconst paciente = todasLinhas.find(item => {\n  const wp = String(item.json.whatsapp || '').replace(/\\D/g, '');\n  return wp === numeroRemetente;\n});\n\nif (!paciente) {\n  return [{ json: { encontrado: false, motivo: 'paciente_nao_encontrado', numero: numeroRemetente } }];\n}\n\n// Não processar se já encerrado ou convertido\nif (paciente.json.fase_cadencia === 'encerrado' ||\n    paciente.json.status === 'convertido' ||\n    paciente.json.status === 'reagendado') {\n  return [{ json: { encontrado: false, motivo: 'cadencia_ja_encerrada', nome: paciente.json.nome_paciente } }];\n}\n\nconst hoje = new Date().toISOString().split('T')[0];\n\nreturn [{\n  json: {\n    encontrado: true,\n    row_number: paciente.json.row_number,\n    nome_paciente: paciente.json.nome_paciente,\n    whatsapp: paciente.json.whatsapp,\n    exame_solicitado: paciente.json.exame_solicitado,\n    valor_orcamento: paciente.json.valor_orcamento,\n    data_agendamento: paciente.json.data_agendamento,\n    fase_cadencia: paciente.json.fase_cadencia,\n    mensagem_recebida: mensagem,\n    data_hoje: hoje\n  }\n}];"
      },
      "id": "b1b2c3d4-0005-0005-0005-100000000005",
      "name": "Identificar Paciente",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1000, 180]
    },
    {
      "parameters": {
        "conditions": {
