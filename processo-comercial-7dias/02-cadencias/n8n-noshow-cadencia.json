    {
      "parameters": {
        "jsCode": "const hoje = new Date();\nhoje.setHours(0, 0, 0, 0);\n\nconst elegíveis = [];\n\nfor (const item of $input.all()) {\n  const d = item.json;\n\n  // Ignorar se não for no-show, se não puder contatar ou se já encerrado\n  if (d.status !== 'noshow') continue;\n  if (String(d.nao_contatar).toUpperCase() === 'TRUE') continue;\n  if (d.fase_cadencia === 'encerrado') continue;\n  if (!d.data_noshow) continue;\n\n  // Calcular dias desde o no-show\n  const partes = String(d.data_noshow).split('-');\n  const dataNs = new Date(Number(partes[0]), Number(partes[1]) - 1, Number(partes[2]));\n  dataNs.setHours(0, 0, 0, 0);\n  const dias = Math.floor((hoje - dataNs) / (1000 * 60 * 60 * 24));\n\n  const fase = String(d.fase_cadencia || '');\n  let faseNova = null;\n\n  if (dias >= 1  && fase === '')    faseNova = 'D1';\n  else if (dias >= 3  && fase === 'D1') faseNova = 'D3';\n  else if (dias >= 7  && fase === 'D3') faseNova = 'D7';\n  else if (dias >= 14 && fase === 'D7') faseNova = 'D14';\n\n  if (!faseNova) continue;\n\n  // Formatar data de hoje para log\n  const meses = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];\n  const logData = String(hoje.getDate()).padStart(2,'0') + meses[hoje.getMonth()];\n\n  elegíveis.push({\n    json: {\n      ...d,\n      fase_nova: faseNova,\n      dias_desde_noshow: dias,\n      log_novo: faseNova + '_enviado_' + logData,\n      data_hoje: hoje.toISOString().split('T')[0]\n    }\n  });\n}\n\nreturn elegíveis;"
      },
