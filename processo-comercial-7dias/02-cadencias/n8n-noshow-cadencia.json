      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Ler No-Show Lab",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [340, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "SUBSTITUIR_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets SST"
        }
      }
