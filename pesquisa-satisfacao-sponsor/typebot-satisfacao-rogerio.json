        {
          "id": "b02_valor",
          "type": "choice input",
          "items": [
            { "id": "val_i1", "content": "Sim, com folga — entrega maior que o investimento" },
            { "id": "val_i2", "content": "Sim, está equilibrado" },
            { "id": "val_i3", "content": "Ainda não sei dizer — preciso ver mais resultado" },
            { "id": "val_i4", "content": "Não, esperava mais pelo valor" }
          ],
          "options": { "variableId": "v02", "isMultipleChoice": false },
          "outgoingEdgeId": "e02_to_g03"
        }
      ]
    },

