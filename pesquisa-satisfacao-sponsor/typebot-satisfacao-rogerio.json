            { "id": "sat_i3", "content": "⭐⭐⭐ Dentro do esperado" },
            { "id": "sat_i4", "content": "⭐⭐⭐⭐ Acima do esperado" },
            { "id": "sat_i5", "content": "⭐⭐⭐⭐⭐ Muito acima do esperado" }
